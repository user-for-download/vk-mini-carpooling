# Local Postgres started by `docker compose up -d postgres` at the repo root.
DATABASE_URL="postgresql://local_blablacar:local_blablacar@localhost:54329/local_blablacar"

# Settings -> General -> Secure key, in your VK Mini App admin panel.
VK_APP_SECRET="paste-your-app-secret-here"

# Comma-separated list of origins allowed to call this API.
# Must include both vk.com and vk.ru domains — VK now serves Mini Apps
# from either, and only checking vk.com will break users on vk.ru.
CORS_ORIGINS="https://vk.com,https://m.vk.com,https://vk.ru,https://m.vk.ru"

PORT=3000

# Maximum number of active bookings per passenger
MAX_BOOKING_COUNT=5

# Mock auth mode — auto-authenticate all requests without VK signatures.
# NEVER set this to true in production (the server will refuse to boot).
VK_AUTH_MOCK_ENABLED=false
