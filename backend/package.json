{
  "name": "@local-blablacar/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "bun run prisma/seed.ts",
    "prisma:seed:test": "bun run prisma/seed-test.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.1.0",
    "@local-blablacar/contracts": "workspace:*",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "dotenv": "^17.4.2",
    "hono": "^4.5.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "@prisma/adapter-pg": {
      "pg": "$pg"
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.14",
    "prisma": "^7.9.0",
    "typescript": "^5.5.0"
  }
}
